# Ignore all CSVs and PNGs by default
*.csv
*.png

# But commit the source dataset
!data/METLIN_IMS_dimers_rmTM.csv

# Commit the Optuna result CSVs (so the tutor can review them in the repo)
!CSVresults/
!CSVresults/*.csv
# Commit the baseline (ECFP4 + FFN) result CSVs
!baseline_results/
!baseline_results/*.csv

# Commit the analysis plots and tables
!Analyze_Results/
!Analyze_Results/**/*.png
!Analyze_Results/**/*.csv

# Trained models and temporary files
train_example/
*.pt
*.ckpt
__pycache__/

# PyTorch Lightning logs and Optuna temporary weights
logs/
optuna_temp/
